generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ORGANIZER
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum ActionType {
  EVENT_VIEWED
  BOOKING_STARTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events        Event[]
  bookings      Booking[]
  activityLogs  ActivityLog[]

  @@map("users")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  venue       String
  eventDate   DateTime
  capacity    Int
  price       Float
  organizerId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer    User          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  activityLogs ActivityLog[]

  @@index([eventDate])
  @@index([organizerId])
  @@map("events")
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  eventId   String
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@map("bookings")
}

model ActivityLog {
  id         String     @id @default(cuid())
  userId     String?
  eventId    String
  actionType ActionType
  createdAt  DateTime   @default(now())

  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([actionType])
  @@map("activity_logs")
}
